{
  "name": "calculadora-tasas",
  "productName": "Calculadora de Tasas",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --port=3001 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "dist:win": "vite build && electron-builder --win portable"
  },
  "dependencies": {
    "@conservatorio/shared": "*",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "typescript": "~5.8.2"
  },
  "build": {
    "appId": "es.cpmarcosredondo.calculadoratasas",
    "productName": "Calculadora de Tasas",
    "electronVersion": "33.4.11",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "CalculadoraTasas-${version}-portable.exe"
    },
    "portable": {
      "artifactName": "CalculadoraTasas-${version}-portable.exe"
    }
  }
}
