# ── Cliente (Vite — incrustado en el bundle en tiempo de build) ───────────────
# Rutas relativas al mismo dominio (funcionan igual en local y en Vercel).
VITE_POWER_AUTOMATE_URL=/api/submit-enrollment
VITE_POWER_AUTOMATE_URL_PDF=/api/upload-pdf

# ── Servidor (Vercel API Routes — NUNCA exponer al cliente) ─────────────────

# Credenciales de la Azure AD App Registration
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_SECRET=tu-secreto-aqui

# Configuración de SharePoint
# URL completa del sitio de SharePoint, ej: https://tenant.sharepoint.com/sites/nombre-sitio
SHAREPOINT_SITE_URL=https://<tenant>.sharepoint.com/sites/<site>
# Nombre exacto de la lista (debe coincidir con la lista creada en SharePoint)
SHAREPOINT_LIST_NAME=Solicitudes de Matrícula
# Nombre exacto de la biblioteca de documentos
SHAREPOINT_LIBRARY_NAME=Documentos Matrícula

# Origen permitido para CORS (el dominio de Vercel o el dominio personalizado)
# En desarrollo puedes usar * pero en producción ponlo específico
ALLOWED_ORIGIN=https://<tu-proyecto>.vercel.app

# ── Dataverse (Microsoft Power Platform) ─────────────────────────────────────
# URL de tu entorno de Dataverse (sin barra final)
# Encuéntrala en: Power Apps → Configuración → Sesión → URL de instancia
DATAVERSE_URL=https://orgXXXXXXXX.crm.dynamics.com
# Nombre del conjunto de entidades (entity set name) de la tabla de matrículas.
# Es el nombre lógico de la tabla en plural, con el prefijo de tu publicador.
# Encuéntralo en: Power Apps → Tablas → tu tabla → Configuración → Nombre del conjunto de entidades
DATAVERSE_TABLE_NAME=cpm_matriculas
# Nombre lógico de la columna tipo File en Dataverse donde se guarda el PDF
# Encuéntralo en: Power Apps → Tablas → tu tabla → Columnas → nombre lógico de la columna PDF
DATAVERSE_FILE_COLUMN=cpmmr_solicitudpdf

# ── Email via Microsoft Graph ─────────────────────────────────────────────────
# Dirección de email desde la que se envían las notificaciones al solicitante.
# La App Registration debe tener el permiso: Mail.Send (Application) en Microsoft Graph.
GRAPH_SENDER_EMAIL=secretaria@tudominio.es

# NOTA: La App Registration de Azure ya está configurada (AZURE_TENANT_ID/CLIENT_ID/SECRET).
# Asegúrate de concederle los permisos en Azure AD:
#   - Dynamics CRM → user_impersonation  (para Dataverse)
#   - Microsoft Graph → Mail.Send        (para enviar email)
# Y añadir el usuario de la aplicación en Dataverse:
# Power Platform Admin Center → Entornos → tu entorno → Usuarios de aplicación → Nuevo usuario de aplicación

# ── Solo desarrollo (opcional) ────────────────────────────────────────────────
GEMINI_API_KEY=tu-clave-gemini
